PORT=5005
PROFILE_SERVICE_URL=http://127.0.0.1:5002
HTTP_TIMEOUT_SECONDS=30

# Nebius AI (OpenAI-compatible) — same provider used in SkillsAssessment
NEBIUS_API_KEY=your_nebius_api_key_here
