# API Gateway environment variables
# Copy this file to .env and fill in real values

# Server
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# Supabase — required
SUPABASE_PROJECT_REF=your-supabase-project-ref
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_JWT_ALG=HS256

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Downstream service URLs
PROFILE_SERVICE_URL=http://127.0.0.1:5002
ASSESSMENT_SERVICE_URL=http://127.0.0.1:5003
CV_SERVICE_URL=http://127.0.0.1:5004
RECOMMENDATION_SERVICE_URL=http://127.0.0.1:5005
RANKING_SERVICE_URL=http://127.0.0.1:5005
CERT_SERVICE_URL=http://127.0.0.1:5006

# Request forwarding timeout (seconds)
REQUEST_TIMEOUT_SECONDS=10
